  "item": [
    {
      "name": "Events",
      "item": [
        {
          "name": "Track Single Event (Test Defaults)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"sess_54321\",\n  \"channel\": \"WEB\",\n  \"feature\": \"dashboard\",\n  \"metadata\": {\n    \"device\": \"desktop\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/events",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "events"]
            }
          }
        },
        {
          "name": "Track Single Event (Invalid Channel Validation)",
          "request": {
            "method": "POST",
