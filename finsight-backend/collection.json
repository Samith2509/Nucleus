              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"sess_98765\",\n  \"channel\": \"UNKNOWN_CHANNEL\",\n  \"feature\": \"login\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/events",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "events"]
            }
          }
        },
