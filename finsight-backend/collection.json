{
  "info": {
    "name": "Finsight Backend API V2",
    "description": "API collection for all endpoints, including new advanced Analytics and Event tracking.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Admin\",\n  \"email\": \"admin@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"ADMIN\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.token) {",
                  "    pm.collectionVariables.set(\"token\", response.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "Track Single Event",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"feature\": \"DASHBOARD_VIEW\",\n  \"channel\": \"WEB\",\n  \"eventType\": \"VIEW\",\n  \"metadata\": { \"browser\": \"Chrome\" }\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            }
          }
        },
        {
          "name": "Track Batch Events",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"events\": [\n    {\n      \"feature\": \"REPORT_DOWNLOAD\",\n      \"eventType\": \"CLICK\"\n    },\n    {\n      \"feature\": \"SETTINGS_UPDATE\",\n      \"eventType\": \"SUBMIT\"\n    }\n  ]\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/events/batch",
              "host": ["{{baseUrl}}"],
              "path": ["events", "batch"]
            }
          }
        },
        {
          "name": "Get Events (Paginated & Filtered)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events?page=1&limit=50&feature=REPORT_DOWNLOAD&channel=WEB",
              "host": ["{{baseUrl}}"],
              "path": ["events"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "50" },
                { "key": "feature", "value": "REPORT_DOWNLOAD" },
                { "key": "channel", "value": "WEB" },
                { "key": "startDate", "value": "2026-01-01", "disabled": true },
                { "key": "endDate", "value": "2026-12-31", "disabled": true }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Dashboard Summary",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/analytics/dashboard",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "dashboard"]
            }
          }
        },
        {
          "name": "Feature Usage Breakdown",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/analytics/feature-usage?startDate=2026-01-01&endDate=2026-12-31",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "feature-usage"],
              "query": [
                { "key": "startDate", "value": "2026-01-01", "disabled": true },
                { "key": "endDate", "value": "2026-12-31", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Funnel Analytics",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/analytics/funnel?journeyId=YOUR_JOURNEY_OBJECT_ID_HERE",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "funnel"],
              "query": [
                { "key": "journeyId", "value": "YOUR_JOURNEY_OBJECT_ID_HERE" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Test & Debug",
      "item": [
        {
          "name": "Create Test Event (Tenant Scope)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"feature\": \"TEST_FEATURE\",\n  \"channel\": \"API\",\n  \"eventType\": \"SYSTEM_TEST\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/test/tenant",
              "host": ["{{baseUrl}}"],
              "path": ["test", "tenant"]
            }
          }
        },
        {
          "name": "Get Tests (Tenant Scope)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/test/tenant",
              "host": ["{{baseUrl}}"],
              "path": ["test", "tenant"]
            }
          }
        },
        {
          "name": "Admin Only Test",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/test/admin",
              "host": ["{{baseUrl}}"],
              "path": ["test", "admin"]
            }
          }
        }
      ]
    }
  ]
}
