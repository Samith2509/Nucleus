{
  "info": {
    "name": "Finsight Backend API test",
    "description": "API collection for Nucleus Finsight Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@finsight.local\",\n  \"password\": \"securepassword\",\n  \"tenantId\": \"641a2b3c4d5e6f7a8b9c0d1e\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@finsight.local\",\n  \"password\": \"securepassword\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Features",
      "item": [
        {
          "name": "Create Feature",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dashboard Analytics\",\n  \"code\": \"dashboard\",\n  \"module\": \"core\",\n  \"description\": \"Main dashboard view\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/features",
              "host": ["{{baseUrl}}"],
              "path": ["features"]
            }
          }
        },
        {
          "name": "Get Features",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/features",
              "host": ["{{baseUrl}}"],
              "path": ["features"]
            }
          }
        }
      ]
    },
    {
      "name": "Journeys",
      "item": [
        {
          "name": "Create Journey",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Customer Onboarding\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/journeys",
              "host": ["{{baseUrl}}"],
              "path": ["journeys"]
            }
          }
        },
        {
          "name": "Add Journey Step",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"journeyId\": \"insert_journey_id_here\",\n  \"stepOrder\": 1,\n  \"stepName\": \"View Dashboard\",\n  \"featureCode\": \"dashboard\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/journeys/step",
              "host": ["{{baseUrl}}"],
              "path": ["journeys", "step"]
            }
          }
        },
        {
          "name": "Get Journey Steps",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/journeys/:journeyId/steps",
              "host": ["{{baseUrl}}"],
              "path": ["journeys", ":journeyId", "steps"],
              "variable": [
                {
                  "key": "journeyId",
                  "value": "insert_journey_id_here"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Consent",
      "item": [
        {
          "name": "Set Consent",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"telemetryEnabled\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/consent",
              "host": ["{{baseUrl}}"],
              "path": ["consent"]
            }
          }
        },
        {
          "name": "Get Consent",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/consent",
              "host": ["{{baseUrl}}"],
              "path": ["consent"]
            }
          }
        }
      ]
    },
    {
      "name": "Audit",
      "item": [
        {
          "name": "Get Audit Logs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/audit",
              "host": ["{{baseUrl}}"],
              "path": ["audit"]
            }
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "Track Single Event",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"sess_123456\",\n  \"channel\": \"WEB\",\n  \"feature\": \"dashboard\",\n  \"eventType\": \"CLICK\",\n  \"metadata\": { \"button\": \"submit\" }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            }
          }
        },
        {
          "name": "Track Batch Events",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"events\": [\n    {\n      \"sessionId\": \"sess_123456\",\n      \"channel\": \"WEB\",\n      \"feature\": \"dashboard\",\n      \"eventType\": \"CLICK\"\n    },\n    {\n      \"sessionId\": \"sess_123456\",\n      \"channel\": \"MOBILE\",\n      \"feature\": \"onboarding\",\n      \"eventType\": \"VIEW\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events/batch",
              "host": ["{{baseUrl}}"],
              "path": ["events", "batch"]
            }
          }
        },
        {
          "name": "Get Events (Paginated)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/events?page=1&limit=50&channel=WEB",
              "host": ["{{baseUrl}}"],
              "path": ["events"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "50" },
                { "key": "channel", "value": "WEB" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Get Dashboard Summary",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/analytics/dashboard",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "dashboard"]
            }
          }
        },
        {
          "name": "Get Feature Usage",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/analytics/feature-usage?startDate=2024-01-01",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "feature-usage"],
              "query": [
                { "key": "startDate", "value": "2024-01-01" },
                { "key": "endDate", "value": "2024-12-31", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Funnel Analytics",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/analytics/funnel?journeyId=insert_journey_id_here",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "funnel"],
              "query": [
                { "key": "journeyId", "value": "insert_journey_id_here" }
              ]
            }
          }
        }
      ]
    }
  ]
}
