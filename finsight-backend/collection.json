              "raw": "{\n  \"events\": [\n    {\n      \"sessionId\": \"sess_batch_1\",\n      \"channel\": \"MOBILE\",\n      \"feature\": \"settings\",\n      \"tenantId\": \"malicious_tenant_id_override_attempt\",\n      \"eventType\": \"click\"\n    },\n    {\n      \"sessionId\": \"sess_batch_2\",\n      \"channel\": \"API\",\n      \"feature\": \"profile\",\n      \"timestamp\": \"2023-01-01T00:00:00.000Z\"\n    }\n  ]\n}"
